# GhostMonitor Server Configuration
# Generated for production deployment

# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (MySQL)
# For local development, use localhost
# For production, use your database provider (PlanetScale, Railway, Aiven, etc.)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=ghostmonitor
DB_SSL=false

# Session Configuration
SESSION_SECRET=ghostmonitor_session_secret_2024_change_in_production

# Admin Configuration
# Generate secure tokens for admin access
ADMIN_TOKENS=admin_token_1,admin_token_2,admin_token_3

# Email Configuration (optional, for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# API Configuration
API_RATE_LIMIT=100
API_TIMEOUT=30000

# Logging
LOG_LEVEL=info
